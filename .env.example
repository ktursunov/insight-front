# Copy this file to `.env.local` and fill in values as needed.
# `.env.local` is gitignored — do not commit tenant secrets.

# Mock API plugins — OFF by default. Set to "true" ONLY when demoing without a
# backend or running UI fixtures. The app renders a yellow warning strip
# whenever mocks are active so synthetic values are never mistaken for real
# data. Prod builds ignore this flag entirely (dead-code eliminated).
VITE_ENABLE_MOCKS=false

# Vite dev server proxy for /api requests. Point at your local backend (e.g.
# a kubectl port-forward). Leave unset for builds that don't need a proxy
# (the proxy block is omitted when this is empty). Prod build is unaffected.
# VITE_API_PROXY_TARGET=http://localhost:8080

# DEV-only impersonation email. When set AND no OIDC session is present, the
# app fetches the matching person from the identity service and uses them as
# the current user. Useful for local dev against a stack with AUTH disabled.
# Prod builds ignore this (gated on import.meta.env.DEV).
# VITE_DEV_USER_EMAIL=you@example.com
#
# When running with mocks (VITE_ENABLE_MOCKS=true), the email MUST match one
# of the people seeded into the mock registry — otherwise the identity mock
# returns 404 and bootstrap halts. Pick one of:
#   bob.park@example.com      — manager, 6 cross-team direct reports (rich menu)
#   carol.chen@example.com    — exec-level, full org subtree
#   alice.kim@example.com     — IC under Bob (minimal menu)
#   frank.moss@example.com    — separate lead with own subtree

# Suppress the mock-data warning banner while VITE_ENABLE_MOCKS is still on.
# Set during screenshot / demo capture when the banner would intrude on the
# image. Mocks themselves keep running. No effect when mocks are off.
# VITE_HIDE_MOCK_BANNER=true